#!/bin/bash
# Quaker launcher.

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    TARGET="$(readlink "$SOURCE")"
    [[ "$TARGET" != /* ]] && SOURCE="$SOURCE_DIR/$TARGET" || SOURCE="$TARGET"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

if [[ -x "$SCRIPT_DIR/bin/qk-go" ]]; then
    exec "$SCRIPT_DIR/bin/qk-go" "$@"
fi

if command -v go > /dev/null 2>&1 && [[ -d "$SCRIPT_DIR/cmd/qk" ]]; then
    exec go run "$SCRIPT_DIR/cmd/qk" "$@"
fi

echo "Quaker binary not found. Run: make build" >&2
exit 127
