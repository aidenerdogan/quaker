#!/bin/bash
# Long-form alias for Quaker.

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    TARGET="$(readlink "$SOURCE")"
    [[ "$TARGET" != /* ]] && SOURCE="$SOURCE_DIR/$TARGET" || SOURCE="$TARGET"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
exec "$SCRIPT_DIR/qk" "$@"
